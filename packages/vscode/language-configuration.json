{
  "comments": {
    "lineComment": "//"
  },
  "brackets": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"]
  ],
  "autoClosingPairs": [
    { "open": "{", "close": "}" },
    { "open": "[", "close": "]" },
    { "open": "(", "close": ")" },
    { "open": "\"", "close": "\"", "notIn": ["string", "comment"] }
  ],
  "surroundingPairs": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"],
    ["\"", "\""]
  ],
  "indentationRules": {
    "increaseIndentPattern": "^.*\\{[^}\"']*(?://.*)?$",
    "decreaseIndentPattern": "^\\s*}"
  },
  "folding": {
    "offSide": false
  },
  "wordPattern": "(-?\\d*\\.?\\d\\w*)|([A-Za-z_][A-Za-z0-9_]*)",
  "onEnterRules": [
    {
      "beforeText": "^\\s*///[ \\t]*\\S.*$",
      "action": { "indent": "none", "appendText": "/// " }
    },
    {
      "beforeText": "^\\s*//![ \\t]*\\S.*$",
      "action": { "indent": "none", "appendText": "//! " }
    }
  ]
}
